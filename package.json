{
  "name": "rewards-points-farmer",
  "version": "1.3.8",
  "description": "Rewards Points Farmer",
  "author": "veegn",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "puppeteer": "^25.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "raw-loader": "^4.0.2",
    "terser-webpack-plugin": "^5.6.1",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "webpack": "^5.108.1",
    "webpack-cli": "^7.1.0"
  },
  "scripts": {
    "build": "webpack",
    "test": "jest",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "test:e2e:live": "npm run build && playwright test --grep @live --workers=1",
    "test:e2e:android": "set PLAYWRIGHT_ANDROID_ADB=1&& npm run build && playwright test --grep @android --workers=1",
    "test:e2e:android:live": "set PLAYWRIGHT_ANDROID_LIVE=1&& npm run build && playwright test --grep @android-live --workers=1",
    "auth:bing": "playwright codegen --save-storage=playwright/.auth/bing.json https://www.bing.com"
  }
}
